# ── Model APIs ──────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-...
OPENAI_API_KEY=sk-...

# ── Database ─────────────────────────────────────────────────
DATABASE_URL=postgresql+asyncpg://forge:forge@localhost:5432/forge
DATABASE_URL_SYNC=postgresql://forge:forge@localhost:5432/forge

# ── Redis ────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379/0

# ── Code Execution ───────────────────────────────────────────
E2B_API_KEY=e2b_...

# ── Auth ─────────────────────────────────────────────────────
JWT_SECRET=change-me-in-production-use-openssl-rand-hex-32
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=10080

# ── App ──────────────────────────────────────────────────────
APP_ENV=development
APP_URL=http://localhost:3000
API_URL=http://localhost:8000
CORS_ORIGINS=http://localhost:3000

# ── Search ───────────────────────────────────────────────────
TAVILY_API_KEY=tvly-...

# ── Observability ────────────────────────────────────────────
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4318
OTEL_SERVICE_NAME=forge-backend
